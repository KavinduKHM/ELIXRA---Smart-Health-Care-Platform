# Base API URL (gateway). If you don't have a gateway, leave as-is and set per-service URLs below.
VITE_API_BASE_URL=http://localhost:8080/api

# Recommended for this repo's docker-compose (per-service URLs)
VITE_PATIENT_BASE_URL=http://localhost:8082/api
VITE_DOCTOR_BASE_URL=http://localhost:8083/api
VITE_APPOINTMENT_BASE_URL=http://localhost:8084/api
VITE_TELEMED_BASE_URL=http://localhost:8085/api
VITE_AI_BASE_URL=http://localhost:8086/api
VITE_PAYMENT_BASE_URL=http://localhost:8087/api
VITE_NOTIFICATION_BASE_URL=http://localhost:8088/api

# Optional auth service (not started in docker-compose.yml)
# VITE_AUTH_BASE_URL=http://localhost:8081/api

# Stripe (test key)
VITE_STRIPE_PUBLISHABLE_KEY=

# Agora
VITE_AGORA_APP_ID=
